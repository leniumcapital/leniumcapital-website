// Supabase Postgres via Vercel integration (auto-synced env vars):
//   POSTGRES_PRISMA_URL       — pooled, for the running app
//   POSTGRES_URL_NON_POOLING  — direct, for migrations (db push / migrate)
// If connecting manually, set those same names in .env — see .env.example.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  password          String
  name              String
  phone             String?
  avatarUrl         String?
  twoFactorEnabled  Boolean          @default(false)
  twoFactorMethod   String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  accounts          TradingAccount[]
}

model TradingAccount {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountType     String
  tier            Int
  balance         Int
  challengeStatus String
  isPrimary       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}
