# ─── Supabase via Vercel integration (auto-synced) ───────────────────────────
# When you connect Supabase in Vercel, these are set automatically:
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""

# Manual Supabase setup (if not using Vercel integration):
# POSTGRES_PRISMA_URL  = Transaction pooler, port 6543, add ?pgbouncer=true
# POSTGRES_URL_NON_POOLING = Direct connection, port 5432

# ─── Auth.js (required in production) ────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# ─── Kalshi (optional — public API works without a key) ────────────────────────
# KALSHI_API_BASE="https://api.elections.kalshi.com/trade-api/v2"
