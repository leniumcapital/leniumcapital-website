# ─── Supabase via Vercel integration (auto-synced) ───────────────────────────
# When you connect Supabase in Vercel, these are set automatically:
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""

# Manual Supabase setup (if not using Vercel integration):
# POSTGRES_PRISMA_URL  = Transaction pooler, port 6543, add ?pgbouncer=true
# POSTGRES_URL_NON_POOLING = Direct connection, port 5432

# ─── Auth.js (required in production) ────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# ─── Google sign-in (optional — buttons appear when both are set) ────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth client ID.
# Authorized redirect URI: https://lenium.capital/api/auth/callback/google
# (and http://localhost:3001/api/auth/callback/google for local dev)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# ─── Apple sign-in (optional — buttons appear when both are set) ─────────────
# Requires an Apple Developer account ($99/yr). AUTH_APPLE_ID is the Services
# ID; AUTH_APPLE_SECRET is the generated client-secret JWT (expires every
# 6 months). Redirect URI: https://lenium.capital/api/auth/callback/apple
# AUTH_APPLE_ID=""
# AUTH_APPLE_SECRET=""

# ─── Kalshi (optional — public API works without a key) ────────────────────────
# KALSHI_API_BASE="https://api.elections.kalshi.com/trade-api/v2"
